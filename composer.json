{
  "name": "demos-europe/demosplan-addon-xbeteiligung-async",
  "description": "This plugin provides Handling of XBeteiligung messages",
  "version": "v0.2-beta",
  "type": "demosplan-addon",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "DemosEurope\\DemosplanAddon\\XBeteiligung\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DemosEurope\\DemosplanAddon\\XBeteiligung\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "beta",
  "require": {
    "demos-europe/demosplan-addon": "^v0.59",
    "demos-europe/demosplan-addon-installer": "^0",
    "doctrine/doctrine-bundle": "^2",
    "doctrine/doctrine-migrations-bundle": "^3.2",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "gedmo/doctrine-extensions": "^3",
    "goetas-webservices/xsd-reader": "^0.3.7",
    "goetas-webservices/xsd2php-runtime": "^0.2.16",
    "jms/serializer": "^3.23",
    "php": ">=8.1 || < 8.3",
    "php-amqplib/rabbitmq-bundle": "2.*",
    "proj4php/proj4php": "^2.0",
    "symfony/http-client": "6.*.*",
    "symfony/http-kernel": "6.*.*",
    "symfony/security-core": "6.*.*"
  },
  "config": {
    "allow-plugins": {
      "demos-europe/demosplan-addon-installer": true
    }
  },
  "require-dev": {
    "liip/functional-test-bundle": "^4",
    "goetas-webservices/xsd2php": "0.4.13",
    "phpstan/phpstan": "^1.10",
    "symfony/phpunit-bridge": "^6.2",
    "symfony/test-pack": "^1.1"
  }
}
