                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="vorgangsID" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Die Vorgangs-ID der Nachrichten 0201, 0301 oder 0401 und der sich darauf beziehenden Nachrichten aus der Beteiligung.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element name="stellungnahmeID" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Die Stellungnahme-ID, die in der Nachricht 0701 von der beteiligten Stelle übermittelt wurde.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:sequence>
            </xs:extension>
         </xs:complexContent>
      </xs:complexType>
   </xs:element>
