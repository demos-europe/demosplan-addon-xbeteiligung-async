   <xs:element name="allgemein.stellungnahme.Neuabgegeben.0701">
      <xs:annotation>
         <xs:appinfo>
            <rechtsgrundlage>Rechtsgrundlage</rechtsgrundlage>
         </xs:appinfo>
         <xs:documentation>Diese Nachricht übermittelt Informationen über eine neu abgegebene Stellungnahme inklusive etwaiger Anhänge an das Planungsportal. Die Informationen enthalten ggf. auch solche, die durch die Behörde erfasst wurden, die das Beteiligungsverfahren durchführt.</xs:documentation>
      </xs:annotation>
      <xs:complexType>
         <xs:complexContent>
            <xs:extension base="bn-g2g:Nachricht.G2GType">
               <xs:sequence>
                  <xs:element name="nachrichteninhalt">
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="vorgangsID" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Vorgangs-ID, die in der Nachricht 0201, 0301 oder 0401 übermittelt wurde.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element name="stellungnahme"
                                       minOccurs="0"
                                       type="xbeteiligung:Stellungnahme">
                              <xs:annotation>
                                 <xs:documentation>Dieses Element enthält die Stellungnahme der beteiligten Stelle.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:sequence>
            </xs:extension>
         </xs:complexContent>
      </xs:complexType>
   </xs:element>
   <xs:element name="allgemein.stellungnahme.Aktualisiert.0702">
      <xs:annotation>
         <xs:appinfo>
            <rechtsgrundlage>Rechtsgrundlage</rechtsgrundlage>
         </xs:appinfo>
         <xs:documentation>Diese Nachricht übermittelt aktualisierte Informationen zu einer bereits übermittelten Stellungnahmen inklusive etwaiger Anhänge an das Planungsportal.</xs:documentation>
      </xs:annotation>
      <xs:complexType>
         <xs:complexContent>
            <xs:extension base="bn-g2g:Nachricht.G2GType">
               <xs:sequence>
                  <xs:element name="nachrichteninhalt">
