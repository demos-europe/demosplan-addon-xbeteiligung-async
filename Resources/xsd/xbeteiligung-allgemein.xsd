         <xs:documentation>Diese Nachricht wird an das Planungsportal versendet und enthält die zum Löschen einer Stellungnahme notwendigen Metadaten.</xs:documentation>
      </xs:annotation>
      <xs:complexType>
         <xs:complexContent>
            <xs:extension base="bn-g2g:Nachricht.G2GType">
