                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="vorgangsID" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Vorgangs-ID, die in der Nachricht 0201, 0301 oder 0401 übermittelt wurde.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element name="stellungnahmeID" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Stellungnahme-ID, die in der Nachricht 0701/0702 übermittelt wurde.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element name="planID" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Die Plan-ID, die in der Nachricht 0201, 0301 oder 0401 übermittelt wurde.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:sequence>
            </xs:extension>
         </xs:complexContent>
      </xs:complexType>
   </xs:element>
   <xs:element name="allgemein.stellungnahme.Neuabgegeben.OK.0711">
      <xs:annotation>
         <xs:appinfo>
            <rechtsgrundlage>Rechtsgrundlage</rechtsgrundlage>
         </xs:appinfo>
         <xs:documentation>Diese Quittierungsnachricht wird nach einer erfolgreichen Einreichung einer neuen Stellungnahme durch das Planungsportal versendet.</xs:documentation>
      </xs:annotation>
      <xs:complexType>
         <xs:complexContent>
