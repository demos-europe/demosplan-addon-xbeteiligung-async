               <xs:documentation>Hier können Georeferenzierungen übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="prioritaet"
                     minOccurs="0"
                     type="xbeteiligung:Code.PrioritaetDerStellungnahme">
