                           type="xibehoerde:Behoerde.ErreichbarType"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Hier wird die Fachbehörde bzw. Organisation genannt, die die vorliegende Nachricht erstellt hat.</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:restriction>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="StellungnahmeType">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp dient der Übermittlung von Stellungnahmen von Institutionen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="stellungnahmeID" type="xink:UUIDType"/>
         <xs:element name="stellungnahmeVerfahrenID" type="dinspec91379:datatypeC"/>
         <xs:element name="beteiligungsID" type="xink:UUIDType"/>
         <xs:element name="planID" type="xink:UUIDType"/>
         <xs:element name="status" type="xbeteiligung:Code.StatusDerStellungnahmeType"/>
         <xs:element name="verfasser" minOccurs="0" type="xbauk:OrganisationType">
            <xs:annotation>
               <xs:documentation>Für die Stellungnahme verantwortliche Organisation bzw. Behörde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="titel" minOccurs="0" type="dinspec91379:datatypeC"/>
         <xs:element name="beschreibung" minOccurs="0" type="dinspec91379:datatypeC"/>
         <xs:element name="datum" minOccurs="0" type="xs:date"/>
         <xs:element name="vormerkung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Code.VormerkungType"/>
         <xs:element name="zuordnung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:ZuordnungType"/>
         <xs:element name="zustimmung" minOccurs="0" type="xbeteiligung:ZustimmungType">
            <xs:annotation>
               <xs:documentation>Element zur Spezifizierung einer Zustimmung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="georeferenzierung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:GeoreferenzierungType"/>
         <xs:element name="prioritaet"
                     minOccurs="0"
                     type="xbeteiligung:Code.PrioritaetDerStellungnahmeType"/>
         <xs:element name="abwaegungsvorschlag"
                     minOccurs="0"
                     type="xbeteiligung:Code.AbwaegungsvorschlagType"/>
         <xs:element name="schlagwort"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="dinspec91379:datatypeC"/>
         <xs:element name="anlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:AnlagenType">
            <xs:annotation>
               <xs:documentation>Die der Stellungsnahme zugehörigen Anlagen werden in diesem Element referenziert.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="UnterverfahrensteilschrittType">
      <xs:sequence>
         <xs:element name="uvtscode"
                     minOccurs="0"
                     type="xbeteiligung:Code.UnterverfahrensteilschrittType"/>
         <xs:element name="mandatory" minOccurs="0" type="xs:boolean"/>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="VerfahrenType">
      <xs:annotation>
         <xs:documentation>Element zur Spezifizierung eines Verfahrens.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="verfahrenstypID" minOccurs="0" type="xs:ID"/>
         <xs:element name="verfahrenstyp"
                     minOccurs="0"
                     type="xbeteiligung:Code.VerfahrenstypType"/>
         <xs:element name="verfahrensteilschritt"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:VerfahrensteilschrittType"/>
         <xs:element name="unterverfahrensteilschritt"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Code.UnterverfahrensteilschrittType"/>
         <xs:element name="zustaendigkeit" type="xbeteiligung:Code.ZustaendigkeitType"/>
         <xs:element name="aktuelleMitteilung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xs:string"/>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="VerfahrensteilschrittType">
      <xs:sequence>
         <xs:element name="verfahrensteilschrittcode"
                     minOccurs="0"
                     type="xbeteiligung:Code.VerfahrensteilschrittType"/>
         <xs:element name="mindestdauer" minOccurs="0" type="xs:int"/>
         <xs:element name="maxdauer" minOccurs="0" type="xs:int"/>
         <xs:element name="unterverfahrensteilschritte"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:UnterverfahrensteilschrittType"/>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="VerfahrensverweisType">
      <xs:sequence>
         <xs:element name="planID" type="xs:ID"/>
         <xs:element name="planname" minOccurs="0" type="dinspec91379:datatypeC"/>
         <xs:element name="arbeitstitel" minOccurs="0" type="dinspec91379:datatypeC"/>
         <xs:element name="verfahrenstyp" type="xbeteiligung:Code.VerfahrenstypType"/>
         <xs:element name="verfahrensart" type="xbeteiligung:Code.VerfahrensartType"/>
         <xs:element name="vfdbID" minOccurs="0" type="dinspec91379:datatypeC"/>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ZeitraumType">
      <xs:annotation>
         <xs:documentation>Der Zeitraum kennzeichnet einen Abschnitt auf einem Zeitstrahl durch Angabe von Beginn und/oder Ende.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="beginn" minOccurs="0" type="xs:date">
            <xs:annotation>
               <xs:documentation>Der Beginn eines Zeitraums beschreibt den Zeitpunkt, ab dem ein Sachverhalt eintritt bzw. rechtskräftig wirksam ist. Der Beginn ist immer Teil der Dauer des Zeitraumes.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="ende" minOccurs="0" type="xs:date">
            <xs:annotation>
               <xs:documentation>Das Ende eines Zeitraumes beschreibt den Zeitpunkt, ab dem ein Sachverhalt endet bzw. nicht mehr rechtskräftig ist. Das Ende ist Teil der Dauer des Zeitraumes.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zusatz" minOccurs="0" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Der Zusatz enthält weitere textuelle Beschreibungen des festgelegten Zeitraums.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ZuordnungType">
      <xs:annotation>
         <xs:documentation>Fachliche Zuordnung einer Stellungnahme.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="zuordnungID" type="xs:ID"/>
         <xs:element name="zuordnungCode"
                     minOccurs="0"
                     type="xbeteiligung:Code.ZuordnungType"/>
         <xs:element name="vonCharNr" minOccurs="0" type="xs:nonNegativeInteger"/>
         <xs:element name="bisCharNr" minOccurs="0" type="xs:nonNegativeInteger"/>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ZustimmungType">
      <xs:annotation>
         <xs:documentation>Element zur Spezifizierung einer Zustimmung in einer Stellungnahme.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="kommunikation"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbauk:KommunikationType">
            <xs:annotation>
               <xs:documentation>"Kommunikation" fasst Angaben zur Erreichbarkeit über elektronische Kommunikationskanäle (z.B. Telefon, Fax, E-Mail) zusammen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerStellungnahme"
                     type="xbeteiligung:Code.ArtDerStellungnahmeType"/>
         <xs:element name="artDerRueckmeldung"
                     type="xbeteiligung:Code.ArtDerRueckmeldungType"/>
         <xs:element name="nutzername" minOccurs="0" type="dinspec91379:datatypeC"/>
      </xs:sequence>
   </xs:complexType>
</xs:schema>
