         </xs:element>
         <xs:element name="artDerStellungnahme" type="xbeteiligung:Code.ArtDerStellungnahme">
            <xs:annotation>
               <xs:documentation>Hier ist die Art der Stellungnahme zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerRueckmeldung" type="xbeteiligung:Code.ArtDerRueckmeldung">
            <xs:annotation>
               <xs:documentation>Hier ist die Art der Rückmeldung zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nutzername" minOccurs="0" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann der Nutzername übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
