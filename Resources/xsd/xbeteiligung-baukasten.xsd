<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:xbeteiligung="https://www.xleitstelle.de/xbeteiligung/1"
           xmlns:dinspec91379="urn:xoev-de:kosit:xoev:datentyp:din-spec-91379_2019-03"
           xmlns:xbauk="http://www.xleitstelle.de/xbau/kernmodul/1/2"
           xmlns:xibehoerde="http://www.osci.de/xinneres/behoerde/5"
           xmlns:xida="http://www.osci.de/xinneres/datum/2"
           xmlns:xink="http://www.osci.de/xinneres/basisnachricht/5"
           xmlns:xoev-code="http://xoev.de/schemata/code/1_0"
           targetNamespace="https://www.xleitstelle.de/xbeteiligung/1"
           version="1.0"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified">
   <xs:annotation>
      <xs:appinfo>
         <standard>
            <nameLang>XBeteiligung</nameLang>
            <nameKurz>XBeteiligung</nameKurz>
            <nameTechnisch>xbeteiligung</nameTechnisch>
            <kennung>urn:xoev-de:xleitstelle:standard:xbeteiligung</kennung>
            <beschreibung>Beteiligungsverfahren - OZG</beschreibung>
         </standard>
         <versionStandard>
            <version>1.0</version>
            <beschreibung>XBeteiligung ist der Standard für Beteiligungsverfahren im Kontext des OZG</beschreibung>
            <versionXOEVProfil>2.1.0_p3</versionXOEVProfil>
            <versionXOEVHandbuch>2.4</versionXOEVHandbuch>
            <versionXGenerator>3.1.0</versionXGenerator>
            <versionModellierungswerkzeug>19.0 SP 3</versionModellierungswerkzeug>
            <nameModellierungswerkzeug>MagicDraw</nameModellierungswerkzeug>
         </versionStandard>
      </xs:appinfo>
   </xs:annotation>
   <xs:include schemaLocation="xbeteiligung-codes.xsd"/>
   <xs:import schemaLocation="din-91379-datatypes.xsd"
              namespace="urn:xoev-de:kosit:xoev:datentyp:din-spec-91379_2019-03"/>
   <xs:import schemaLocation="xbau-kernmodul-datentypen.xsd"
              namespace="http://www.xleitstelle.de/xbau/kernmodul/1/2"/>
   <xs:import schemaLocation="xinneres-basisnachricht.xsd"
              namespace="http://www.osci.de/xinneres/basisnachricht/5"/>
   <xs:import schemaLocation="xinneres-behoerde.xsd"
              namespace="http://www.osci.de/xinneres/behoerde/5"/>
   <xs:import schemaLocation="xinneres-datum.xsd"
              namespace="http://www.osci.de/xinneres/datum/2"/>
   <xs:import schemaLocation="xoev-code.xsd"
              namespace="http://xoev.de/schemata/code/1_0"/>
   <xs:complexType name="AkteurRolle">
      <xs:annotation>
         <xs:documentation>Dieser Typ bezeichnet die Rolle eines am Vorhaben beteiligten Akteurs.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="code" type="xbeteiligung:Code.AkteurRolle">
            <xs:annotation>
               <xs:documentation>Angabe der Rolle des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtgelisteterWert" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für die Rolle des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="AkteurVorhaben">
      <xs:annotation>
         <xs:documentation>Der Datentyp benennt Akteure des Vorhabens, für das eine Beteiligung initiert wird. Der Veranlasser ist immer zu benennen, weitere Akteure können mit ihrer Rolle übermittelt werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="veranlasser" type="xbauk:OrganisationType">
            <xs:annotation>
               <xs:documentation>Hier wird Behörde oder Stelle genannt, die für das Verfahren rechtlich verantwortlich ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="weitereAkteure" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Dieser Abschnitt fasst die Daten zu einem weiteren Akteur zusammen. Für jeden Akteur ist ein Element zu instanziieren.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="akteur" type="xbauk:OrganisationType">
                     <xs:annotation>
                        <xs:documentation>Daten des Beteilgten.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="rolle" type="xbeteiligung:AkteurRolle">
                     <xs:annotation>
                        <xs:documentation>Hier ist die Rolle des Beteiligten anzugeben.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Anlagen">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient dazu, die Metadaten zu Verfahrensunterlagen aufzunehmen, die einer XBeteiligungs-Kommunikation als Anlagen beigefügt sind.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anlage"
                     maxOccurs="unbounded"
                     type="xbeteiligung:MetadatenAnlage"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Jede Instanz dieses Elements steht für eine Anlage (Primärdokument) zur übermittelten Fachnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AnlagenLink">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient dazu, die Metadaten zu Verfahrensunterlagen aufzunehmen, die einer XBeteiligungs-Kommunikation als Anlagen beigefügt sind. Die Übermittlung von Dokumenten ist nicht möglich.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anlage"
                     maxOccurs="unbounded"
                     type="xbeteiligung:MetadatenAnlageLink"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Jede Instanz dieses Elements steht für eine Anlage (Primärdokument) zur übermittelten Fachnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Beteiligung">
      <xs:annotation>
         <xs:documentation>Mit diesem Datentyp können die Informationen zu einem Beteiligungsverfahren übermittelt werden, wahlweise im Rahmen der kommunalen Bauleitplanung, der Raumordnung oder der Planfeststellung.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="kommunal" type="xbeteiligung:BeteiligungKommunal">
            <xs:annotation>
               <xs:documentation>Hier können die Informationen zu einem Beteiligungsverfahren im Rahmen der kommunalen Bauleitplanung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="raumordnung" type="xbeteiligung:BeteiligungRaumordnung">
            <xs:annotation>
               <xs:documentation>Hier können die Informationen zu einem Beteiligungsverfahren im Rahmen der Raumordnung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planfeststellung" type="xbeteiligung:BeteiligungPlanfeststellung">
            <xs:annotation>
               <xs:documentation>Hier können die Informationen zu einem Beteiligungsverfahren im Rahmen der Planfeststellung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="BeteiligungKommunal">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält alle Informationen zu einem Beteiligungsverfahren im Rahmen der kommunalen Bauleitplanung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="akteurVorhaben" type="xbeteiligung:AkteurVorhaben">
            <xs:annotation>
               <xs:documentation>Hier sind Informationen zu den am Planungsvorhaben beteiligten Akteuren zu übermitteln. Mindestens der Veranlasser ist zu benennen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planID" type="xink:UUIDType">
            <xs:annotation>
               <xs:documentation>Hier ist die ID des Planverfahrens zu übermitteln, innerhalb dessen das Beteiligungsverfahren durchgeführt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planname" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist der Name des Planvorhabens zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="arbeitstitel" minOccurs="0" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann der Arbeitstitel übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planartKommunal"
                     minOccurs="0"
                     type="xbeteiligung:Code.PlanartKommunal">
            <xs:annotation>
               <xs:documentation>Hier kann die Art des Planverfahrens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verfahrensschrittKommunal"
                     type="xbeteiligung:Code.Verfahrensschritt">
            <xs:annotation>
               <xs:documentation>Hier ist der Verfahrensschritt zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verfahrensartKommunal"
                     minOccurs="0"
                     type="xbeteiligung:Code.VerfahrensartKommunal">
            <xs:annotation>
               <xs:documentation>Hier kann die Art des Beteiligungsverfahrens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beschreibungPlanungsanlass"
                     minOccurs="0"
                     type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann die fachliche Beschreibung des Planverfahrens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="flaechenabgrenzungUrl" minOccurs="0" type="xs:anyURI">
            <xs:annotation>
               <xs:documentation>Hier kann zur Visualisierung der Flächenabgrenzung eine URL auf einen Kartendienst übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="geltungsbereich" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist die räumliche Beschreibung des Geltungsbereichs als Polygon im Format GeoJSON FG Notation zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="raeumlicheBeschreibung" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist der räumliche Geltungsbereich zu beschreiben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungURL" minOccurs="0" type="xs:anyURI">
            <xs:annotation>
               <xs:documentation>Hier kann eine URL übermittelt werden, unter der Detailinformationen zum Beteiligungsverfahren eingesehen werden können.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungOeffentlichkeit"
                     minOccurs="0"
                     type="xbeteiligung:BeteiligungKommunalOeffentlichkeit">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zur Beteiligung der Öffentlichkeit gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungTOEB"
                     minOccurs="0"
                     type="xbeteiligung:BeteiligungKommunalTOEB">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zur Beteiligung der Träger öffentlicher Belange gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BeteiligungKommunalDB">
      <xs:annotation>
         <xs:documentation>Komponente der Datentypen, die eine Aufforderung zur Beteiligung beschreiben.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="akteurVorhaben" type="xbeteiligung:AkteurVorhaben">
            <xs:annotation>
               <xs:documentation>Am Planungsvorhaben beteiligte Akteure.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planID" type="xink:UUIDType">
            <xs:annotation>
               <xs:documentation>Hier ist die ID des Planverfahrens zu übermitteln, innerhalb dessen das Beteiligungsverfahren durchgeführt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planname" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist der Name des Planverfahrens zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="arbeitstitel" minOccurs="0" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann der Arbeitstitel übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planart"
                     minOccurs="0"
                     type="xbeteiligung:Code.PlanartKommunal">
            <xs:annotation>
               <xs:documentation>Hier kann die Art des Planverfahrens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verfahrensart"
                     minOccurs="0"
                     type="xbeteiligung:Code.VerfahrensartKommunal">
            <xs:annotation>
               <xs:documentation>Hier kann die Art des Beteiligungsverfahrens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beschreibungPlanungsanlass"
                     minOccurs="0"
                     type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann die fachliche Beschreibung des Planverfahrens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verfahrensschritt" type="xbeteiligung:Code.Verfahrensschritt">
            <xs:annotation>
               <xs:documentation>Hier ist der Verfahrensschritt zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="durchgang" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier ist die Durchgangsnummer des Beteiligungsverfahren zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="flaechenabgrenzungUrl" minOccurs="0" type="xs:anyURI">
            <xs:annotation>
               <xs:documentation>URL eines Kartendienstes</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="geltungsbereich" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist die räumliche Beschreibung des Geltungsbereichs als Polygon im Format GeoJSON FG Notation zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="raeumlicheBeschreibung" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist der räumliche Geltungsbereich zu beschreiben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bekanntmachung" type="xida:TagesdatumType">
            <xs:annotation>
               <xs:documentation>Termin, zu dem der Start der Beteiligung bekannt gemacht wird (mind. eine Woche vor Start der Beteiligung).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="aktuelleMitteilung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xs:string">
            <xs:annotation>
               <xs:documentation>Hier können auktuelle Mitteilungen übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zeitraum" minOccurs="0" type="xbeteiligung:Zeitraum">
            <xs:annotation>
               <xs:documentation>Zeitraum (Beginn und Ende) einer Beteiligungsphase.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="veroeffentlichungszeitraum"
                     minOccurs="0"
                     type="xbeteiligung:Zeitraum">
            <xs:annotation>
               <xs:documentation>Hier kann der Zeitraum (Beginn und Ende) übermittelt werden, für den die Dokumente zu einer Beteiligungsphase öffentlich bereitgestellt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:AnlagenLink">
            <xs:annotation>
               <xs:documentation>Die für die Beteiligung erforderlichen Anlagen und Verfahrensunterlagen werden in diesem Element referenziert. Für die Übermittlung an die Beteiligungs-DB ist nur die Übermittlung von Links auf Unterlagen zulässig.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BeteiligungKommunalOeffentlichkeit">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält alle Informationen zu einem Beteiligungsverfahren im Rahmen der kommunalen Bauleitplanung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="beteiligungsID" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier muss eine Zeichenkette übermittelt werden, die zur Zuordnung von Stellungnahmen zu einzelnen Beteiligungsverfahren genutzt werden kann.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="durchgang" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier ist die Durchgangsnummer des Verfahrens zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bekanntmachung" type="xida:TagesdatumType">
            <xs:annotation>
               <xs:documentation>Termin, zu dem der Start der Beteiligung bekannt gemacht wird (mind. eine Woche vor Start der Beteiligung).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="aktuelleMitteilung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xs:string">
            <xs:annotation>
               <xs:documentation>Hier können aktuelle Mitteilungen übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zeitraum" type="xbeteiligung:Zeitraum">
            <xs:annotation>
               <xs:documentation>Zeitraum (Beginn und Ende) einer Beteiligungsphase.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Anlagen">
            <xs:annotation>
               <xs:documentation>Die für die Beteiligung erforderlichen Anlagen und Verfahrensunterlagen werden in diesem Element referenziert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungKommunalOeffentlichkeitArt">
            <xs:annotation>
               <xs:documentation>Hier ist zu übermitteln, um welche Art der Öffentlichkeitsbeteiligung es sich handelt.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:choice>
                  <xs:element name="beteiligungKommunalFormalOeffentlichkeit"
                              type="xbeteiligung:Code.Verfahrensschritt">
                     <xs:annotation>
                        <xs:documentation>Hier ist zu übermitteln, ob es sich um eine frühzeitige Öffentlichkeitsbeteiligung (4000) oder eine öffentliche Auslegung (6000) handelt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beteiligungKommunalInformellOeffentlichkeit">
                     <xs:annotation>
                        <xs:documentation>Hier kann die Art des informellen Verfahrens zur Beteiligung der Öffentlichkeit übermittelt werden.</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:complexContent>
                           <xs:restriction base="xoev-code:Code">
                              <xs:sequence>
                                 <xs:element name="code" type="xs:token" form="unqualified"/>
                                 <xs:element name="name" type="xs:normalizedString" form="unqualified"/>
                              </xs:sequence>
                              <xs:attribute name="listURI" type="xs:anyURI" use="required"/>
                              <xs:attribute name="listVersionID" type="xs:normalizedString" use="required"/>
                           </xs:restriction>
                        </xs:complexContent>
                     </xs:complexType>
                  </xs:element>
               </xs:choice>
            </xs:complexType>
         </xs:element>
         <xs:element name="veroeffentlichungszeitraum"
                     minOccurs="0"
                     type="xbeteiligung:Zeitraum">
            <xs:annotation>
               <xs:documentation>Hier kann der Zeitraum (Beginn und Ende) übermittelt werden, für den die Dokumente zu einer Beteiligungsphase öffentlich bereitgestellt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BeteiligungKommunalTOEB">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält alle Informationen zu einem Beteiligungsverfahren im Rahmen der kommunalen Bauleitplanung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="beteiligungsID" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier muss eine Zeichenkette übermittelt werden, die zur Zuordnung von Stellungnahmen zu einzelnen Beteiligungsverfahren genutzt werden kann.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="durchgang" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier ist die Durchgangsnummer des Verfahrens zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bekanntmachung" type="xida:TagesdatumType">
            <xs:annotation>
               <xs:documentation>Termin, zu dem der Start der Beteiligung bekannt gemacht wird (mind. eine Woche vor Start der Beteiligung).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="aktuelleMitteilung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xs:string">
            <xs:annotation>
               <xs:documentation>Hier können aktuelle Mitteilungen übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zeitraum" type="xbeteiligung:Zeitraum">
            <xs:annotation>
               <xs:documentation>Zeitraum (Beginn und Ende) einer Beteiligungsphase.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Anlagen">
            <xs:annotation>
               <xs:documentation>Die für die Beteiligung erforderlichen Anlagen und Verfahrensunterlagen werden in diesem Element referenziert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungKommunalTOEBArt">
            <xs:annotation>
               <xs:documentation>Hier ist zu übermitteln, um welche Art der Beteiligung der Träger öffentlicher Belange es sich handelt.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:choice>
                  <xs:element name="beteiligungKommunalFormalTOEB"
                              type="xbeteiligung:Code.Verfahrensschritt">
                     <xs:annotation>
                        <xs:documentation>Hier ist zu übermitteln, ob es sich um eine frühzeitige Behördenbeteiligung (2000) oder eine Beteiligung der Träger öffentlicher Belange (5000) handelt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
