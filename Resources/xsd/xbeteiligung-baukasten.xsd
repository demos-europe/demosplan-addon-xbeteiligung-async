                     type="xbeteiligung:Code.VerfahrensschrittRaumordnung">
            <xs:annotation>
               <xs:documentation>Hier ist der Verfahrensschritt für ein Raumordnungsverfahren zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Fehler">
      <xs:annotation>
         <xs:documentation>Dieser Typ beschreibt einen Fehler.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="beschreibung" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist die Beschreibung des Fehlers zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="art" minOccurs="0" type="xbeteiligung:Code.Fehlerart">
            <xs:annotation>
               <xs:documentation>Hier kann die Art des Fehlers übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="FehlerhafteUnterlage">
      <xs:annotation>
         <xs:documentation>Dieser Typ beschreibt eine fehlerhafte Unterlage.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="fehlerbeschreibung" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist die Beschreibung des Fehlers zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="dokumentID" type="xs:token">
            <xs:annotation>
               <xs:documentation>ID der fehlerhaften Unterlage.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="art" minOccurs="0" type="xbeteiligung:Code.Fehlerart">
            <xs:annotation>
               <xs:documentation>Hier kann die Art des Fehlers übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Georeferenzierung">
      <xs:annotation>
         <xs:documentation>Element zur Verortung der einer Stellungnahme.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="punkt"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbauk:GeoreferenziertePunkte">
            <xs:annotation>
               <xs:documentation>Hier können georefierenzierte Punkte zur Verwortung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="flaeche"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbauk:GeoreferenzierteFlaeche">
            <xs:annotation>
               <xs:documentation>Hier können georefierenzierte Flächen zur Verwortung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="linie"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbauk:GeoreferenzierteLinie">
            <xs:annotation>
               <xs:documentation>Hier können georefierenzierte Linien zur Verwortung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="MetadatenAnlage">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp bildet die Metadaten zu einer Anlage ab. Er basiert auf der Modellierung des XBau-Kernmoduls 1.2, erlaubt aber im Gegensatz zu diesem auch die Übermittlung von Anhängen innerhalb der Fachnachricht als base64-codiertem Binary. Bei der Übermittlung innerhalb der Fachnachricht ist darauf zu achten, dass die Größe der Fachnachricht inkl. Dokument 128 MB nicht überschreitet.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bezeichnung"
                     minOccurs="0"
                     type="din91379:datatypeC"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist eine deskriptive Bezeichnung der Anlage einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="versionsnummer"
                     minOccurs="0"
                     type="din91379:datatypeC"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist eine Versionsnummer einzutragen. Sie dient dazu, Anlagen zu unterscheiden, die dieselbe Bezeichnung tragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datum" minOccurs="0" type="xs:date" form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist das Datum der Erstellung bzw. der letzten Bearbeitung dieser Anlage einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlageart"
                     minOccurs="0"
                     type="xbeteiligung:Code.Verfahrensunterlagetyp"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist, falls möglich die Dokumentenkategorie anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="mimeType" type="xbauk:Code.XBau-MimeType" form="unqualified">
            <xs:annotation>
               <xs:documentation>Dieses Element nennt - analog zur Übermittlung von E-Mail-Anlagen - den MIME-Typ der angehängten oder verlinkten Anlage (z.B. text/xml, text/plain, application/gzip oder application/pdf). Die Angabe ist mandatorisch, weil eine für den Empfänger zur Verarbeitung der Daten notwendige Information.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anhangOderVerlinkung"
                     minOccurs="0"
                     type="xbeteiligung:AnhangOderVerlinkung"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Dieses Elements enthält die Angabe, ob die Anlage (i) als Anhang mit dieser XBeteiligungs-Nachricht übermittelt wird, (ii) über einen Link zugänglich gemacht wird, der in diese XBeteiligungs-Nachricht eingetragen ist oder ob sie (iii) base64-codiert innerhalb dieser XBeteiligungs-Nachricht übermittelt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="dokument" minOccurs="0" type="xs:base64Binary">
            <xs:annotation>
               <xs:documentation>Hier kann das anzuhängende Dokument, beschrieben in anhangOderVerlinkung/anhang, base64-codiert direkt innerhalb der Fachnachricht übermittelt werden, solange die Größe der Nachricht 128 MB nicht übersteigt. Alternativ kann das Dokument als weiteres Dokument im gleichen Transportumschlag übermittelt werden. Zur Referenzierung dienen die dokumentid und dateiname aus dem Element anhangOderVerlinkung/anhang.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="MetadatenAnlageLink">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp bildet die Metadaten zu einer Anlage ab. Er basiert auf dem Datentyp quotMetadatenAnlagequot aus dem XBau-Kernmodul. Mit diesem Datentyp ist allerdings nur die Übermittlung von Links auf Dokumente möglich.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bezeichnung"
                     minOccurs="0"
                     type="din91379:datatypeC"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier kann eine deskriptive Bezeichnung der Anlage übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="versionsnummer"
                     minOccurs="0"
                     type="xs:positiveInteger"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier kann eine Versionsnummer übermittelt werden. Sie dient dazu, Anlagen zu unterscheiden, die dieselbe Bezeichnung tragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datum" minOccurs="0" type="xs:date" form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier kann das Datum der Erstellung bzw. der letzten Bearbeitung dieser Anlage übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlageart"
                     minOccurs="0"
                     type="xbeteiligung:Code.Verfahrensunterlagetyp"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist, falls möglich die Dokumentenkategorie anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="link" type="xs:anyURI" form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist die URL zu übermitteln, unter der die Anlage abrufbar ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Nachrichteninhalt.template.NOK">
      <xs:annotation>
         <xs:documentation>Vorlage für negative Quittungsnachrichten</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="vorgangsID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier wird die Vorgangs-ID übermittelt, die in der Ursprungsnachricht übermittelt wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier wird die Plan-ID übermittelt, die in der Ursprungsnachricht übermittelt wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="fehler"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Fehler">
            <xs:annotation>
               <xs:documentation>Hier kann die Beschreibung des Fehlers übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="fehlerhafteUnterlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:FehlerhafteUnterlage">
            <xs:annotation>
               <xs:documentation>In diesem Element können fehlerhafte Planungsunterlagen beschrieben werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Nachrichteninhalt.template.OK">
      <xs:annotation>
         <xs:documentation>Vorlage für positive Quittungsnachrichten</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="vorgangsID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier wird Vorgangs-ID übermittelt, die in der Ursprungsnachricht übermittelt wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier wird die Plan-ID übermittelt, auf die sich die Ursprungsnachricht bezieht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungsID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier wird die Beteiligungs-ID übermittelt, auf die sich die Ursprungsnachricht bezieht.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Organisation">
      <xs:annotation>
         <xs:appinfo>
            <title>Vereinfachte Angaben zu einer Organisation</title>
         </xs:appinfo>
         <xs:documentation>Mit diesem Datentyp können Informationen zu einer Organisation üermittelt werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="name" type="xs:string">
            <xs:annotation>
               <xs:documentation>Hier ist der Name der Organisation zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="organisationseinheit" minOccurs="0" type="xs:string">
            <xs:annotation>
               <xs:documentation>Hier kann der Name der Organisationseinheit (z. B. Abteilung, Referat) übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Rolle">
      <xs:annotation>
         <xs:documentation>Dieser Typ bezeichnet die Rolle eines am Vorhaben beteiligten Akteurs.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="code" type="xbeteiligung:Code.Rolle">
            <xs:annotation>
               <xs:documentation>Angabe der Rolle des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtgelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für die Rolle des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Stellungnahme">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp dient der Übermittlung von Stellungnahmen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="stellungnahmeID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier ist die ID der Stellungsnahme zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="planID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier ist die ID des Planverfahrens zu übermittleln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligungsID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier ist die ID der Beteiligung zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="status" type="xbeteiligung:Code.StatusDerStellungnahme">
            <xs:annotation>
               <xs:documentation>Hier ist der Status der Stellungsnahme zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verfasser" minOccurs="0" type="xbeteiligung:Verfasser">
            <xs:annotation>
               <xs:documentation>Für die Stellungnahme verantwortliche Organisation bzw. Behörde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="titel" minOccurs="0" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann ein Titel übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beschreibung" minOccurs="0" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann die Beschreibung der Stellungnahme übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="durchgang" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier ist die Nummer des Durchgangs des Verfahrensteilschritts zu übermitteln, in dem die Stellungnahme abgegeben wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datum" minOccurs="0" type="xs:date">
            <xs:annotation>
               <xs:documentation>Hier kann das Datum der Stellungnahme übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerStellungnahme"
                     minOccurs="0"
                     type="xbeteiligung:Code.ArtDerStellungnahme">
            <xs:annotation>
               <xs:documentation>Hier ist die Art der Stellungnahme zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerRueckmeldung"
                     minOccurs="0"
                     type="xbeteiligung:Code.ArtDerRueckmeldung">
            <xs:annotation>
               <xs:documentation>Hier ist die Art der Rückmeldung zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:choice>
            <xs:annotation>
               <xs:documentation>Hier ist durch Angabe des Verfahrensschritt zu übermitteln, zu welcher Art Beteiligungsverfahren die Stellungnahme abgegeben wurde.</xs:documentation>
            </xs:annotation>
            <xs:element name="verfahrensschrittPlanfeststellung"
                        type="xbeteiligung:Code.VerfahrensschrittPlanfeststellung">
               <xs:annotation>
                  <xs:documentation>Hier ist der Verfahrensschritt für ein Planfeststellungsverfahren zu übermitteln.</xs:documentation>
               </xs:annotation>
            </xs:element>
            <xs:element name="verfahrensschrittKommunal"
                        type="xbeteiligung:Code.VerfahrensschrittKommunal">
               <xs:annotation>
                  <xs:documentation>Hier ist der Verfahrensschritt für ein Verfahren der kommunalen Bauleitplanung zu übermitteln.</xs:documentation>
               </xs:annotation>
            </xs:element>
            <xs:element name="verfahrensschrittRaumordnung"
                        type="xbeteiligung:Code.VerfahrensschrittRaumordnung">
               <xs:annotation>
                  <xs:documentation>Hier ist der Verfahrensschritt für ein Raumordnungsverfahren zu übermitteln.</xs:documentation>
               </xs:annotation>
            </xs:element>
         </xs:choice>
         <xs:element name="verfahrensteilschritt"
                     type="xbeteiligung:Code.Verfahrensteilschritt">
            <xs:annotation>
               <xs:documentation>Hier ist der Verfahrensteilschritt zu übermitteln, zu dem die Stellungnahme abgegeben wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zuordnung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Zuordnung">
            <xs:annotation>
               <xs:documentation>Hier kann die Zuordnung zum Gegenstand der Stellungnahme erfolgen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="georeferenzierung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Georeferenzierung">
            <xs:annotation>
               <xs:documentation>Hier können Georeferenzierungen übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="prioritaet"
                     minOccurs="0"
                     type="xbeteiligung:Code.PrioritaetDerStellungnahme">
            <xs:annotation>
               <xs:documentation>Hier kann die Priorität der Stellungnahme übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="abwaegungsvorschlag"
                     minOccurs="0"
                     type="xbeteiligung:Code.Abwaegungsvorschlag">
            <xs:annotation>
               <xs:documentation>Hier kann ein Abwägungsvorschlag zur Stellungnahme übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="schlagwort"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier können Schlagwörter übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbeteiligung:Anlagen">
            <xs:annotation>
               <xs:documentation>Die der Stellungsnahme zugehörigen Anlagen werden in diesem Element referenziert.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:simpleType name="Tagesdatum">
      <xs:annotation>
         <xs:appinfo>
            <title>Vollständig bekanntes Datum</title>
         </xs:appinfo>
         <xs:documentation>Mit diesem Datentyp wird ein vollständig bekanntes Datum übermittelt. Anders als in xs:date ist hier die Angabe einer Zeitzone jedoch nicht möglich. Dieser Datentyp entspricht dem in XInneres verwendeten Datentyp Tagesdatum.</xs:documentation>
      </xs:annotation>
      <xs:restriction base="xs:date">
         <xs:pattern value="[0-9]{4}-[0-9]{2}-[0-9]{2}"/>
      </xs:restriction>
   </xs:simpleType>
   <xs:complexType name="Verfasser">
      <xs:annotation>
         <xs:appinfo>
            <title>Verfasser einer Stellungnahme</title>
         </xs:appinfo>
         <xs:documentation>Dieser Datentyp wird verwendet, um die Angaben zum Verfasser einer Stellungnahme zu übermitteln.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="privatperson"
                     minOccurs="0"
                     fixed="true"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Falls es sich beim Verfasser der Stellungnahme um eine Privatperson handelt, ist hier true zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="name" type="xbauk:NameNatuerlichePerson">
            <xs:annotation>
               <xs:documentation>Hier ist der Name der Person anzugeben, die die Stellungnahme als Privatperson oder im Namen einer Organisation verfasst.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="organisation" minOccurs="0" type="xbeteiligung:Organisation">
            <xs:annotation>
               <xs:documentation>Wird die Stellungnahme für eine Organisation verfasst, so sind hier die Angaben der Organisation zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anschrift" minOccurs="0" type="xbauk:Anschrift">
            <xs:annotation>
               <xs:documentation>Hier kann die Anschrift übermittelt werden, unter der der Verfasser erreichbar ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="kommunikation"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbauk:Kommunikation">
            <xs:annotation>
               <xs:documentation>Hier kann übermittelt werden, wie der Verfasser der Stellungnahme zu erreichen ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Zeitraum">
      <xs:annotation>
         <xs:documentation>Der Zeitraum kennzeichnet einen Abschnitt auf einem Zeitstrahl durch Angabe von Beginn und/oder Ende.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="beginn" minOccurs="0" type="xs:date">
            <xs:annotation>
               <xs:documentation>Der Beginn eines Zeitraums beschreibt den Zeitpunkt, ab dem ein Sachverhalt eintritt bzw. rechtskräftig wirksam ist. Der Beginn ist immer Teil der Dauer des Zeitraumes.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="ende" minOccurs="0" type="xs:date">
            <xs:annotation>
               <xs:documentation>Das Ende eines Zeitraumes beschreibt den Zeitpunkt, ab dem ein Sachverhalt endet bzw. nicht mehr rechtskräftig ist. Das Ende ist Teil der Dauer des Zeitraumes.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zusatz" minOccurs="0" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Der Zusatz enthält weitere textuelle Beschreibungen des festgelegten Zeitraums.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Zuordnung">
      <xs:annotation>
         <xs:documentation>Fachliche Zuordnung einer Stellungnahme.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="zuordnungID" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier ist die ID der Zuordnung zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zuordnungCode"
                     minOccurs="0"
                     type="xbeteiligung:Code.Zuordnung">
            <xs:annotation>
               <xs:documentation>Hier kann der Code der Zuordnung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="vonCharNr" minOccurs="0" type="xs:nonNegativeInteger">
            <xs:annotation>
               <xs:documentation>Hier kann der Beginn der Zurordnung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bisCharNr" minOccurs="0" type="xs:nonNegativeInteger">
            <xs:annotation>
               <xs:documentation>Hier kann das Ende der Zuordnung übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
</xs:schema>
