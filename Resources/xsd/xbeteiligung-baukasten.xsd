            </xs:annotation>
         </xs:element>
         <xs:element name="beschreibung" minOccurs="0" type="dinspec91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann die Beschreibung der Stellungnahme übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datum" minOccurs="0" type="xs:date">
            <xs:annotation>
               <xs:documentation>Hier kann das Datum der Stellungnahme übermittelt werden.</xs:documentation>
